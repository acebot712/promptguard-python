{
  "_description": "Shared contract tests for PromptGuard SDKs. Both Python and Node SDKs MUST pass all cases in this file. If you add a feature to one SDK, add a test case here first.",
  "_version": "1.5.0",

  "guard_decision": {
    "description": "GuardDecision must parse these API response bodies correctly.",
    "cases": [
      {
        "name": "allow_decision",
        "input": {
          "decision": "allow",
          "event_id": "evt-allow-1",
          "confidence": 0.05,
          "threats": [],
          "latency_ms": 3.2
        },
        "expect": {
          "allowed": true,
          "blocked": false,
          "redacted": false,
          "event_id": "evt-allow-1",
          "confidence": 0.05,
          "threat_type": null
        }
      },
      {
        "name": "block_decision",
        "input": {
          "decision": "block",
          "event_id": "evt-block-1",
          "confidence": 0.95,
          "threat_type": "prompt_injection",
          "threats": [
            {
              "type": "prompt_injection",
              "confidence": 0.95,
              "details": "Detected instruction override"
            }
          ],
          "latency_ms": 12.5
        },
        "expect": {
          "allowed": false,
          "blocked": true,
          "redacted": false,
          "event_id": "evt-block-1",
          "confidence": 0.95,
          "threat_type": "prompt_injection"
        }
      },
      {
        "name": "redact_decision",
        "input": {
          "decision": "redact",
          "event_id": "evt-redact-1",
          "confidence": 0.88,
          "threat_type": "pii",
          "redacted_messages": [{ "role": "user", "content": "My SSN is [REDACTED]" }],
          "threats": [{ "type": "pii", "confidence": 0.88, "details": "SSN detected" }],
          "latency_ms": 8.1
        },
        "expect": {
          "allowed": false,
          "blocked": false,
          "redacted": true,
          "event_id": "evt-redact-1",
          "confidence": 0.88,
          "threat_type": "pii",
          "redacted_messages_count": 1,
          "redacted_first_content": "My SSN is [REDACTED]"
        }
      },
      {
        "name": "empty_response_is_rejected",
        "_comment": "A malformed/empty body must NOT silently default to allow; SDKs must raise their API-error type so the caller's explicit failOpen policy governs (audit round 1, finding 5).",
        "input": {},
        "expect_error": "GuardApiError"
      },
      {
        "name": "unknown_decision_is_rejected",
        "input": {
          "decision": "maybe",
          "event_id": "evt-bad-1",
          "confidence": 0.5,
          "threats": [],
          "latency_ms": 1.0
        },
        "expect_error": "GuardApiError"
      }
    ]
  },

  "redaction_enforcement": {
    "description": "How the shared patch wrapper must handle a pre-call redact decision (added in v1.5.0, audit round 4 findings 1-2). Each case drives the SDK's central decision handling with `scanned_messages` (the guard messages that were scanned), a `decision` API body, a `mode`, and `has_redaction_applier` (whether the SDK patch supplies a redaction handler for this call shape). `expect` is one of: 'apply' (the redacted contents MUST be forwarded to the wrapped call), 'block' (the SDK's blocked error MUST be raised and the wrapped call MUST NOT run), 'passthrough' (monitor mode only: warn and forward the ORIGINAL content unchanged). A redact decision whose redacted_messages are missing, empty, or SHORTER than the scanned messages cannot be honored and must escalate to block in enforce mode.",
    "cases": [
      {
        "name": "redact_with_full_payload_applies_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": true,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-1",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [{ "role": "user", "content": "My SSN is [REDACTED]" }],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "apply"
      },
      {
        "name": "redact_without_payload_blocks_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": true,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-2",
          "confidence": 0.9,
          "threat_type": "pii",
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "block"
      },
      {
        "name": "redact_with_empty_payload_blocks_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": true,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-3",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "block"
      },
      {
        "name": "redact_with_partial_payload_blocks_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": true,
        "scanned_messages": [
          { "role": "user", "content": "My SSN is 123-45-6789" },
          { "role": "user", "content": "My card is 4111-1111-1111-1111" }
        ],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-4",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [{ "role": "user", "content": "My SSN is [REDACTED]" }],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "block"
      },
      {
        "name": "redact_without_applier_blocks_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": false,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-5",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [{ "role": "user", "content": "My SSN is [REDACTED]" }],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "block"
      },
      {
        "name": "redact_with_extra_payload_applies_in_enforce",
        "mode": "enforce",
        "has_redaction_applier": true,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-6",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [
            { "role": "user", "content": "My SSN is [REDACTED]" },
            { "role": "user", "content": "extra entry is ignored" }
          ],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "apply"
      },
      {
        "name": "redact_without_payload_passes_through_in_monitor",
        "mode": "monitor",
        "has_redaction_applier": true,
        "scanned_messages": [{ "role": "user", "content": "My SSN is 123-45-6789" }],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-7",
          "confidence": 0.9,
          "threat_type": "pii",
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "passthrough"
      },
      {
        "name": "redact_with_partial_payload_passes_through_in_monitor",
        "mode": "monitor",
        "has_redaction_applier": true,
        "scanned_messages": [
          { "role": "user", "content": "My SSN is 123-45-6789" },
          { "role": "user", "content": "My card is 4111-1111-1111-1111" }
        ],
        "decision": {
          "decision": "redact",
          "event_id": "evt-re-8",
          "confidence": 0.9,
          "threat_type": "pii",
          "redacted_messages": [{ "role": "user", "content": "My SSN is [REDACTED]" }],
          "threats": [],
          "latency_ms": 1.0
        },
        "expect": "passthrough"
      }
    ]
  },

  "message_conversion": {
    "description": "OpenAI-style messages must be converted to guard format identically across SDKs.",
    "cases": [
      {
        "name": "simple_text_messages",
        "input": [
          { "role": "system", "content": "You are helpful." },
          { "role": "user", "content": "Hello" }
        ],
        "expect": [
          { "role": "system", "content": "You are helpful." },
          { "role": "user", "content": "Hello" }
        ]
      },
      {
        "name": "multimodal_content_extracts_text_only",
        "input": [
          {
            "role": "user",
            "content": [
              { "type": "text", "text": "What is in this image?" },
              { "type": "image_url", "image_url": { "url": "https://example.com/img.png" } }
            ]
          }
        ],
        "expect": [{ "role": "user", "content": "What is in this image?" }]
      },
      {
        "name": "empty_messages_returns_empty",
        "input": [],
        "expect": []
      }
    ]
  },

  "anthropic_message_conversion": {
    "description": "Anthropic messages with separate system param must be handled identically.",
    "cases": [
      {
        "name": "string_system_prompt",
        "input_messages": [{ "role": "user", "content": "Hello" }],
        "input_system": "Be helpful",
        "expect": [
          { "role": "system", "content": "Be helpful" },
          { "role": "user", "content": "Hello" }
        ]
      },
      {
        "name": "content_block_system_prompt",
        "input_messages": [{ "role": "user", "content": "Hello" }],
        "input_system": [{ "type": "text", "text": "Be helpful" }],
        "expect": [
          { "role": "system", "content": "Be helpful" },
          { "role": "user", "content": "Hello" }
        ]
      },
      {
        "name": "no_system_prompt",
        "input_messages": [{ "role": "user", "content": "Hello" }],
        "input_system": null,
        "expect": [{ "role": "user", "content": "Hello" }]
      }
    ]
  },

  "google_content_conversion": {
    "description": "Google Generative AI content must be converted identically.",
    "cases": [
      {
        "name": "string_input",
        "input": "Hello world",
        "expect": [{ "role": "user", "content": "Hello world" }]
      },
      {
        "name": "array_of_strings",
        "input": ["Hello", "World"],
        "expect": [{ "role": "user", "content": "Hello" }, { "role": "user", "content": "World" }]
      },
      {
        "name": "content_object_with_parts",
        "input": [{ "role": "user", "parts": [{ "text": "What is 2+2?" }] }],
        "expect": [{ "role": "user", "content": "What is 2+2?" }]
      }
    ]
  },

  "blocked_error": {
    "description": "PromptGuardBlockedError must format message consistently.",
    "cases": [
      {
        "name": "with_threat_type",
        "decision": {
          "decision": "block",
          "event_id": "evt-err-1",
          "confidence": 0.92,
          "threat_type": "prompt_injection",
          "threats": [],
          "latency_ms": 5
        },
        "expect_message_contains": ["prompt_injection", "0.92", "evt-err-1"]
      },
      {
        "name": "without_threat_type_falls_back_to_policy_violation",
        "decision": {
          "decision": "block",
          "event_id": "evt-err-2",
          "confidence": 0.5,
          "threats": [],
          "latency_ms": 3
        },
        "expect_message_contains": ["policy_violation"]
      }
    ]
  },

  "guard_request_payload": {
    "description": "GuardClient._build_payload must produce identical JSON.",
    "cases": [
      {
        "name": "minimal_payload",
        "args": {
          "messages": [{ "role": "user", "content": "Hi" }],
          "direction": "input"
        },
        "expect": {
          "messages": [{ "role": "user", "content": "Hi" }],
          "direction": "input"
        }
      },
      {
        "name": "full_payload",
        "args": {
          "messages": [{ "role": "user", "content": "Hi" }],
          "direction": "output",
          "model": "gpt-5-nano",
          "context": { "framework": "langchain" }
        },
        "expect": {
          "messages": [{ "role": "user", "content": "Hi" }],
          "direction": "output",
          "model": "gpt-5-nano",
          "context": { "framework": "langchain" }
        }
      }
    ]
  }
}
